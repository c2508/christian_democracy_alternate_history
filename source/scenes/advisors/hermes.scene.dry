@agriculture
title: Agricultural Policy
subtitle: Hermes is the Minister of Agriculture.
choose-if: advisor_action_timer <= 0 and z_in_government and agriculture_minister_party == "Z"
unavailable-subtitle: [? if advisor_action_timer > 0 : [+ advisor_action_timer +] months before next advisor action. ?][? if not z_in_government : The <span style="color: #000000;">**Center Party**</span> is not in government. ?][? if agriculture_minister_party != "Z": The <span style="color: #000000;">**Center Party**</span> does not have the Agriculture Ministry. ?]
on-arrival: advisor_action_timer = 6; agricultural_policy_timer -= 6; last_advisor_action = 1
go-to: agricultural_policy


