{!<tr><td>!} <span style="color: #D3C24D;">**[+ ddp_name +]**</span>: {!</td><td>!} [+ ddp_r +]% {!</td><td>!} [+ ddp_seats +] {!</td></tr>!}

{!<tr><td>!} <span style="color: #C0A054;">**DVP**</span>: {!</td><td>!} [+ dvp_r +]% {!</td><td>!} [+ dvp_seats +] {!</td></tr>!}

{!<tr><td>!} <span style="color: #B8996F;">**WP**</span>: {!</td><td>!} [+ wp_r +]% {!</td><td>!} [+ wp_seats +] {!</td></tr>!}

{!<tr><td>!} <span style="color: #006400;">**CNBLP**</span>: {!</td><td>!} [+ cnblp_r +] % {!</td><td>!} [+ cnblp_seats +] {!</td></tr>!}

{!<tr><td>!} <span style="color: #3E88B3;">**DNVP**</span>: {!</td><td>!} [+ dnvp_r +]% {!</td><td>!} [+ dnvp_seats +] {!</td></tr>!}

